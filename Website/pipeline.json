{
  "$schema": "https://raw.githubusercontent.com/EvotecIT/PSPublishModule/main/schemas/powerforge.web.pipelinespec.schema.json",
  "cache": true,
  "cachePath": "./_temp/pipeline-cache.json",
  "profile": true,
  "profilePath": "./_temp/pipeline-profile.json",
  "steps": [
    {
      "task": "dotnet-build",
      "id": "build-dnsclientx",
      "project": "../DnsClientX/DnsClientX.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "dotnet-build",
      "id": "build-powershell",
      "project": "../DnsClientX.PowerShell/DnsClientX.PowerShell.csproj",
      "configuration": "Release",
      "framework": "net8.0",
      "skipIfProjectMissing": true
    },
    {
      "task": "exec",
      "id": "sync-powershell-apidocs",
      "dependsOn": ["build-powershell"],
      "command": "pwsh",
      "argsList": [
        "-NoLogo",
        "-NoProfile",
        "-File",
        "./scripts/Sync-DnsClientXApiDocs.ps1",
        "-SiteRoot",
        "."
      ],
      "workingDirectory": "."
    },
    {
      "task": "build",
      "id": "build-site",
      "dependsOn": [
        "build-dnsclientx",
        "build-powershell",
        "sync-powershell-apidocs"
      ],
      "config": "./site.json",
      "out": "./_site",
      "clean": true
    },
    {
      "task": "verify",
      "id": "verify-site",
      "dependsOn": "build-site",
      "config": "./site.json"
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-dotnet",
      "dependsOn": ["build-dnsclientx", "build-site"],
      "config": "./site.json",
      "xml": "../DnsClientX/bin/Release/net8.0/DnsClientX.xml",
      "assembly": "../DnsClientX/bin/Release/net8.0/DnsClientX.dll",
      "out": "./_site/api/dnsclientx",
      "title": "DnsClientX .NET API Reference",
      "baseUrl": "/api/dnsclientx",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css",
      "sourceRoot": "..",
      "sourceUrl": "https://github.com/EvotecIT/DnsClientX/blob/main/{path}#L{line}",
      "includeNamespace": "DnsClientX",
      "injectCriticalCss": true
    },
    {
      "task": "apidocs",
      "id": "build-apidocs-powershell",
      "dependsOn": ["build-site", "sync-powershell-apidocs"],
      "config": "./site.json",
      "type": "PowerShell",
      "helpPath": "./data/apidocs/powershell/DnsClientX.PowerShell.dll-Help.xml",
      "psManifestPath": "./data/apidocs/powershell/DnsClientX.psd1",
      "psExamplesPath": "./data/apidocs/powershell/examples",
      "out": "./_site/api/powershell",
      "title": "DnsClientX PowerShell Cmdlet Reference",
      "baseUrl": "/api/powershell",
      "format": "both",
      "legacyAliasMode": "omit",
      "template": "docs",
      "bodyClass": "pf-api-docs pf-api-docs--powershell",
      "docsHome": "/products/powershell/",
      "nav": "./site.json",
      "navContextPath": "/",
      "css": "/css/app.css,/css/api.css",
      "injectCriticalCss": true
    },
    {
      "task": "xref-merge",
      "id": "merge-xref",
      "dependsOn": [
        "build-apidocs-dotnet",
        "build-apidocs-powershell"
      ],
      "out": "./data/xrefmap.json",
      "mapFiles": [
        "./_site/api/dnsclientx/xrefmap.json",
        "./_site/api/powershell/xrefmap.json"
      ],
      "preferLast": true,
      "maxReferences": 25000,
      "maxDuplicates": 100
    },
    {
      "task": "build",
      "id": "build-site-xref-refresh",
      "dependsOn": "merge-xref",
      "config": "./site.json",
      "out": "./_site",
      "clean": false
    },
    {
      "task": "verify",
      "id": "verify-ci",
      "dependsOn": "build-site-xref-refresh",
      "modes": ["ci"],
      "config": "./site.json",
      "baseline": "./.powerforge/verify-baseline.json",
      "failOnNewWarnings": true,
      "failOnNavLint": true,
      "failOnThemeContract": true
    },
    {
      "task": "optimize",
      "id": "optimize-site",
      "dependsOn": "build-site-xref-refresh",
      "skipModes": ["dev"],
      "siteRoot": "./_site",
      "config": "./site.json",
      "criticalCss": "./themes/dnsclientx/critical.css",
      "minifyHtml": true,
      "minifyCss": true,
      "minifyJs": true,
      "optimizeImages": true,
      "hashAssets": true,
      "hashExtensions": [".css", ".js"],
      "hashExclude": [
        "**/assets/prism/components/**",
        "**/css/prism-theme.css"
      ],
      "cacheHeaders": true,
      "cacheHeadersOut": "_headers"
    },
    {
      "task": "audit",
      "id": "audit-ci",
      "dependsOn": "optimize-site",
      "modes": ["ci"],
      "config": "./site.json",
      "siteRoot": "./_site",
      "baseline": "./.powerforge/audit-baseline.json",
      "failOnNewIssues": true,
      "navSelector": "header nav",
      "navCanonicalPath": "index.html",
      "navCanonicalRequired": true,
      "requiredRoutes": "/,/docs/,/404.html,/api/,/api/dnsclientx/,/api/powershell/,/playground/,/downloads/,/products/dnsclientx/,/products/powershell/"
    },
    {
      "task": "doctor",
      "id": "doctor-site",
      "dependsOn": "optimize-site",
      "skipModes": ["dev", "ci"],
      "config": "./site.json",
      "siteRoot": "./_site",
      "noBuild": true,
      "noVerify": true,
      "navSelector": "header nav",
      "navCanonicalPath": "index.html",
      "navCanonicalRequired": true,
      "requiredRoutes": "/,/docs/,/404.html,/api/,/api/dnsclientx/,/api/powershell/,/playground/,/downloads/,/products/dnsclientx/,/products/powershell/"
    }
  ]
}
